{
  "rewrites": [
    { "source": "/desembre", "destination": "/desembre/index.html" },
    { "source": "/desembre/(.*)", "destination": "/desembre/index.html" },
    { "source": "/dermagarden", "destination": "/dermagarden/index.html" },
    { "source": "/dermagarden/(.*)", "destination": "/dermagarden/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
